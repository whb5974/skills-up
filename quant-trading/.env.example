# ===========================================
# 量化交易 API 配置
# ===========================================

# Tushare API (https://tushare.pro)
TUSHARE_TOKEN=your_tushare_token_here

# 聚宽 JoinQuant (https://www.joinquant.com)
JOINQUANT_USERNAME=your_username
JOINQUANT_PASSWORD=your_password

# Alpha Vantage (https://www.alphavantage.co)
ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# 数据库配置
DATABASE_URL=sqlite:///data/quant.db

# 交易配置
DEFAULT_CAPITAL=100000    # 默认资金 (元)
MAX_POSITION=0.3          # 单只股票最大仓位 (30%)
STOP_LOSS=0.05            # 止损比例 (5%)
TAKE_PROFIT=0.15          # 止盈比例 (15%)

# 日志配置
LOG_LEVEL=INFO
